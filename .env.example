# Supabase (obrigatório)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua_anon_key

# Frontend - variáveis injetadas no build (Vite)
# Necessárias para docker-compose build do web
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key

# URL da API (visível pelo browser no fetch)
# Em Docker local: http://localhost:3001
# Em produção: https://api.seudominio.com
VITE_API_URL=http://localhost:3001

# API - CORS (origens permitidas, separadas por vírgula)
# Em produção: https://seu-dominio.com,https://www.seu-dominio.com
CORS_ORIGINS=
